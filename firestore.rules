rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Offres d'emploi : lecture seule pour tout utilisateur authentifié
    // Écriture uniquement via le script Admin SDK (GitHub Actions)
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Profil utilisateur : accès réservé au propriétaire de l'espace
    match /users/{workspaceName} {
      allow read: if request.auth != null &&
                     request.auth.token.email == workspaceName + "@candidator.internal";

      // Seul le champ appliedJobIds peut être mis à jour par l'utilisateur
      allow update: if request.auth != null &&
                       request.auth.token.email == workspaceName + "@candidator.internal" &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['appliedJobIds']);
    }

    // Paramètres de recherche : tout utilisateur authentifié peut lire et modifier
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}

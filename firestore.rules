rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Offres d'emploi : lecture seule pour tout utilisateur authentifié
    // Écriture uniquement via le script Admin SDK (GitHub Actions)
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Profil utilisateur : accès réservé au propriétaire de l'espace
    match /users/{workspaceName} {
      allow read: if request.auth != null &&
                     request.auth.token.email == workspaceName + "@candidator.internal";

      // Création du document à la première connexion
      allow create: if request.auth != null &&
                       request.auth.token.email == workspaceName + "@candidator.internal";

      // Seuls appliedJobIds et searchKeywords peuvent être modifiés par l'utilisateur
      allow update: if request.auth != null &&
                       request.auth.token.email == workspaceName + "@candidator.internal" &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['appliedJobIds', 'searchKeywords']);
    }

    // Config : lecture seule pour les utilisateurs authentifiés
    // Écriture désactivée côté client (le script Admin SDK n'est pas affecté)
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}

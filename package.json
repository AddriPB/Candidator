{
  "name": "opportunity-radar",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"vite --host 0.0.0.0\"",
    "server:dev": "node --watch server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "scan:once": "node server/cli/scan-once.js",
    "db:init": "node server/cli/db-init.js",
    "test": "node --test server/**/*.test.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "vite": "^5.3.1"
  }
}

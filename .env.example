NODE_ENV=production
PORT=4173
HOST=0.0.0.0
DATABASE_PATH=./data/opportunity-radar.sqlite

# Long unique password for the single private user.
# Prefer AUTH_PASSWORD_HASH in production. AUTH_PASSWORD is accepted for local setup.
AUTH_PASSWORD=replace-with-a-long-random-password
AUTH_SESSION_SECRET=replace-with-a-long-random-session-secret
AUTH_COOKIE_SECURE=false
SESSION_MAX_AGE_DAYS=30

# Scheduler on the Raspberry Pi. Example: every 6 hours.
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=360

FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
RAPIDAPI_KEY=
CAREERJET_AFFILIATE_ID=
